# ===================================================
# LIFE LEVEL — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores.
# Na Vercel, configure estas MESMAS variáveis em
# Settings > Environment Variables.
# ===================================================

# --- Banco de dados Turso (OBRIGATÓRIO) ---
TURSO_DATABASE_URL=libsql://seu-banco.turso.io
TURSO_AUTH_TOKEN=seu_token_turso_aqui

# --- Login com Google (OPCIONAL) ---
# Sem isto, o botão "Entrar com Google" fica desativado,
# mas o login por email/senha continua funcionando normalmente.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# URL de callback — em produção use seu domínio da Vercel:
# https://seu-projeto.vercel.app/api/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
